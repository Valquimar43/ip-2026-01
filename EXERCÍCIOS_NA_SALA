package main
import "fmt"

func fatorial (n int)int{
        if n < 0 {
            return 0 //Não existe fatorial negativos
        }
        if n == 0 || n == 1 {
            return 1
        }
        return n * fatorial(n - 1)
}
func main(){
    fmt.Println(fatorial(4)) //a saída deve ter como resultado 24
}
