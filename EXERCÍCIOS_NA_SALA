package main
import "fmt"
    //A linha abaixo se refere a função para retornar o maior numero inteiro entre os 3.
func maiorDosTres(a, b, c int) (int, int) {
    
    maior := a //começa assumindo o maior valor
    posicao :=1
    
    //compara b (posição 2)
    if b > maior{
        maior = b //se b for maior, atualiza
        posicao =2
    }
    if c > maior{
        maior = c //se o c for maior, atualiza
        posicao =3
    }
    return maior, posicao //devolve o maior valor/numero
}
func main() {
    var valor1, valor2, valor3 int
    
    fmt.Print("Digite o primeiro valor:")
    fmt.Scan(&valor1)
    
    fmt.Print("Digite o segundo valor:")
    fmt.Scan(&valor2)
    
    fmt.Print("Digite o terceiro valor:")
    fmt.Scan(&valor3)
    
    maior, pos := maiorDosTres(valor1, valor2, valor3)
    
    fmt.Println("O maior valor é: ", maior)
    fmt.Println("A sua posição é: ", pos)
