/*EXERCÍCIO 1 - AULA 06-04-2026
package main

import "fmt"

type Pessoa struct {
	Nome       string
	Altura     float64
	PesoIdeal  float64
}

func calcularPesoIdeal(altura float64) float64 {
	return 72.7 * altura - 58.0
}

func main() {
	var pessoas []Pessoa

	for {
		var p Pessoa

		fmt.Print("Digite o nome (ou 'FIM' para encerrar): ")
		fmt.Scan(&p.Nome)

		if p.Nome == "FIM" {
			break
		}

		fmt.Print("Digite a altura (ex: 1.75): ")
		fmt.Scan(&p.Altura)

		p.PesoIdeal = calcularPesoIdeal(p.Altura)

		pessoas = append(pessoas, p)
	}

	fmt.Println("\n========== Lista de Pessoas ==========")
	for i, p := range pessoas {
		fmt.Printf("\nPessoa %d:\n", i+1)
		fmt.Printf("  Nome:       %s\n", p.Nome)
		fmt.Printf("  Altura:     %.2f m\n", p.Altura)
		fmt.Printf("  Peso Ideal: %.2f kg\n", p.PesoIdeal)
	}
	fmt.Println("======================================")
}
