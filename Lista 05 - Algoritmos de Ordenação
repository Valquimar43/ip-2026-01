# EXERCÍCIO 22 - CONTROLE BANCÁRIO (COM MENU INTERATIVO)
package main

import "fmt"

func main() {
    var codigos [10]int
    var saldos [10]float64
    
    //Leitura das contas
    fmt.Println("Cadastro de 10 contas bancárias:")
    for i := 0; i < 10; i++ {
        fmt.Printf("Digite o código da conta %d: ", i+1)
        fmt.Scan(&codigos[i])
        
        //Verifica se o código já existe (para não repetir)
        for j := 0; i < i; j++ {
            if codigos[j] == codigos[i] {
                fmt.Println("Código já existente! Digite outro:")
                i--     //Refaz esta interação.
                break
            }
        }
        
        
        //Só pede saldo se o código for inválido
        if i >= 0 && (i == 0 || codigos[i] != codigos[i - 1]) {
            fmt.Printf("Digite o saldo da conta %d: ", codigos[i])
            fmt.Scan(&saldos[i])
        }
    }
    
    
    //Função auxiliar para buscar pelo código.
    buscarConta := func(codigo int) (int, bool) {
        for i, c := range codigos {
            if c == codigo {
                return i, true  //Retorna índice e true
            }
        }
        return -1, false
    }
    
    //MENU interativo
    for {
        fmt.Println("\n===== MENU =====")
        fmt.Println("1. Efetuar depósito")
        fmt.Println("2. Efetuar Saque")
        fmt.Println("3. Consultar ativo bancário")
        fmt.Println("4. Finalizar programa")
        fmt.Println("Opção: ")
        
        
        var opcao int
        fmt.Scan(&opcao)
        
        switch opcao {
        case 1:     //Depósito
            var codigo int
            var valor float64
            fmt.Print("Código da conta: ")
            fmt.Scan(&codigo)
            fmt.Print("Valor do depósito: ")
            fmt.Scan(&valor)
            
            
            if idx, ok := buscarConta(codigo); ok {
                saldos[idx] += valor
                fmt.Printf("Depósito realizado! Novo saldo: R$%.2f\n", saldos[idx])
            }else{
                fmt.Println("Conta não encontrada!")
            }
        case 2:     //Saque
            var codigo int
            var valor float64
            fmt.Print("Código da conta: ")
            fmt.Scan(&codigo)
            fmt.Print("Valor do saque: ")
            fmt.Scan(&valor)
            
            
            if idx, ok := buscarConta(codigo); ok {
                if saldos[idx] >= valor{
                    saldos[idx] -= valor
                    fmt.Printf("Saque realizado! Novo saldo: R$%.2f\n", saldos[idx])
                }else{
                    fmt.Println("Saldo insuficiente!")
                }
              
            }else{
                fmt.Println("Conta não encontrada!")
        }
        case 3:     //Consulta ativo bancário
        total := 0.0
        for _, saldo := range saldos {
            total += saldo
        }
        fmt.Printf("Ativo bancário total: R$%.2f\n", total)
        
        case 4:     //Finaliza o programa
        fmt.Println("Programa finalizado.")
        return
        
        default:
        fmt.Println("Opção inválida! Tente novamente.")
        }
    }
}
