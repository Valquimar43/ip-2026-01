# EXERCÍCIO 17 - NÚMEROS PRIMOS E SUAS POSIÇÕES
package main

import "fmt"

func ehPrimo(n int) bool {
    if n < 2 {
        return false
    }
    
    //Verifica os divisores de 2 até a raiz quadrada de n
    for i := 2; i*i <= n; i++ {
        if n%i == 0 {
            return false        //Encontrou um divisor -> não é primo
        }
    }
    return true
}

func main() {
    var vetor [10]int
    
    fmt.Println("Digite 10 números inteiros:")
    for i := 0; i < 10; i++ {
        fmt.Scan(&vetor[i])
    }
    fmt.Println("Números e suas posições:")
    for i, val := range vetor {
        if ehPrimo(val) {
            fmt.Printf("Número %d na posição %d\n", val, i)
        }
    }
}
