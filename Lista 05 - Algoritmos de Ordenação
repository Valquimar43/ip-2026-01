# EXERCÍCIO 2 - PARES SOMADOS E IMPARES SOMADOS COM SEGUNDO VETOR

package main

import "fmt"

func main(){
    //Declarando os vetores
    var primeiro [10] int
    var segundo [5] int
    
    //Leitura do 1º vetor
    fmt.Println("Digite 10 números para o primeiro vetor: ")
    for i := 0; i < 10; i++ {
        fmt.Scan(&primeiro[i])
    }
    //Leitura do 2º vetor
    fmt.Println("Digite 5 números para o segundo vetor: ")
    for i := 0; i < 5; i++ {
        fmt.Scan(&segundo[i])
    }
    //Faz o soma de todos os elementos do segundo vetor
    somaSegundo := 0
    for _, val := range segundo {
        somaSegundo += val
    }
        //Aqui são os vetores resultantes
    var resultPares []int       //Slice dinâmico
    var resultImpares []int     //Slice dinâmico
    
        //Verifica para cada elemento do primeiro vetor, se é par ou ímpar.
    for _, val := range primeiro {
        if val%2 == 0 {
            resultPares = append(resultPares, val + somaSegundo)
        }else{
            resultImpares = append(resultImpares, val + somaSegundo)
        }
    }
    
    fmt.Println("Primeiro vetor resultante (pares + soma do segundo):", resultPares)
    fmt.Println("Segundo vetor resultante (ímpares + soma do segundo):", resultImpares)
    
