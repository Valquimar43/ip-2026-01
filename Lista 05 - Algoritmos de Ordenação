                if poltrona >= 0 && poltrona < 24 && janela[poltrona] == 0 {
                    janela[poltrona] = 1    //Ocupa a poltrona
                    fmt.Println("Poltrona inválida ou já ocupada!")
                }
            }
        case 2:     //CORREDOR
            livres := 0
            for i := 0; i < 24; i++ {
                if corredor[i] ==0 {
                    livres++
                }
            }
            
            if livres == 0{
                fmt.Println("Não existem poltronas livres no corredor!")
            }else{
                fmt.Printf("Poltronas disponíveis no corredor (%d livres): \n", livres)
                for i := 0; i < 24; i++ {
                    if corredor[i] == 0 {
                        fmt.Printf("Corredor %d ", i+1)
                    }
                }
                fmt.Println()
                
                //Escolha da poltrona no corredor
                var poltrona int
                fmt.Print("Digite o número da poltrona desejada: ")
                fmt.Scan(&poltrona)
                poltrona--  //Ajusta para índice 0-based
                
                if poltrona >= 0 && poltrona < 24 && corredor[poltrona] == 0 {
                    corredor[poltrona] = 1    //Ocupa a poltrona
                    fmt.Println("Poltrona reservado com sucesso!")
                } else{
                    fmt.Println("Poltrona inválida ou já ocupada!")
                }
            }
        case 3:     //CONDIÇÃO PARA VERIFICAR A LOTAÇÃO
            totalJanela := 0
            totalCorredor := 0
            for i := 0; i < 24; i++ {
                if janela[i] == 1 {
                    totalJanela++
                }
                if corredor[i] == 1 {
                    totalCorredor++
                }
            }
            totalOcupados := totalJanela + totalCorredor
            fmt.Printf("Janela: %d/24 ocupados\n", totalJanela)
            fmt.Printf("Corredor: %d/24 ocupados\n", totalCorredor)
            fmt.Printf("Total: %d/24 ocupados\n", totalOcupados)
        
            if totalOcupados == 48 {
                fmt.Println("Ônibus completamente cheio!")
            }
        case 4:     //SAIR
            fmt.Println("Sistema encerrado.")
            return
            
            default:
            fmt.Println("Opção inválida!")
        }
    }
