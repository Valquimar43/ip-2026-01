# EXERCÍCIO 8 - RAIZ QUADRADA COM TRATAMENTO DE NEGATIVO
package main

import (
    "fmt"
    "math"
)

func main() {
    var numeros [15]float64
    var raizes [15]float64
    
    fmt.Println("Digite 15 números: ")
    for i := 0; i < 15; i++ {
        fmt.Scan(&numeros[i])
    }
    
    //Calcula a raiz quadrada ou atribui -1
    for i, val := range numeros {
        if val < 0 {
            raizes[i] = -1      //para valores negativos -> -1
        }else{
            raizes[i] = math.Sqrt(val)     //Calcula a raiz quadrada
        }
    }
    
    fmt.Println("Raízes quadradas (ou -1 se negativo): ")
    for _, val := range raizes {
        fmt.Printf("%.2f ", val)
    }
    fmt.Println()
}
