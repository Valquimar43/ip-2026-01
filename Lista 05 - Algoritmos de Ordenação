# EXERCÍCIO 10 - SÉRIE DE FIBONACCI (50 TERMOS)
package main

import "fmt"

func main() {
    var fibonacci [50]int
    
    //Os dois primeiros termos da série são 1 e 1
    fibonacci[0] = 1
    fibonacci[1] = 1
    
    //A partir do terceiro termo: cada termo é a soma dos dois anteriores
    for i := 2; i < 50; i++ {
        fibonacci[i] = fibonacci[i-1] + fibonacci[i-2]
    }
    
    fmt.Println("Os 50 primeiros termos da série de Fibonacci: ")
    for i, val := range fibonacci {
        fmt.Printf("F[%d] = %d\n", i+1, val)
    }
}
