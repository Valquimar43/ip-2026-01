# EXERCÍCIO 13 - TRÊS EMPREGADOS MAIS RECENTES
package main

import "fmt"

func main() {
    type Empregado struct {
        numero int
        meses int
    }
    
    var empregados [] Empregado     //Slice dinâmico para até 100
    
    fmt.Println("Digite numero do empregado e meses de trabalho ( 0 0 para sair):")
    for {
        var num, meses int
        fmt.Scan(&num, &meses)
        
        //Condição de parada: ambos iguais a zero
        if num == 0 && meses == 0 {
            break
        }
        empregados = append(empregados, Empregado{num, meses})
        if len(empregados) > 100 {
            break
        }
    }
    
    //Ordenação simples (Bubble Sort) por meses (menor = mais recente)
    //Queremos os 3 com MENOS meses de trabalho
    for i := 0; i < len(empregados)-1; i++ {
        for j := i + 1; j < len(empregados); j++ {
            if empregados[j].meses < empregados[i].meses {
                empregados[i], empregados[j] = empregados[j], empregados[i]
            }
    }
}
fmt.Println("\nOs 3 empregados mais recentes:")
limite := 3
if len(empregados) < 3 {
    limite = len(empregados)
}
for i := 0; i < limite; i++ {
    fmt.Printf("Empregado %d - %d meses de trabalho\n", empregados[i].numero, empregados[i].meses)
}
}
