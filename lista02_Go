Exercício 13 - Algarismo de cada dezena
package main
import "fmt"
func main(){
    var numero int
    
    fmt.Printf("Digite um Nº inteiro de 3 casas: ")
    fmt.Scan(&numero)
    
    if numero < 100 || numero > 999 { //valida se a entrada possui realmente 3 casas decimais entre 100 e 999
        fmt.Printf("ERRO: O número não tem 3 casas!")
        return //caso não tenha os três digitos o programa para aqui!
    }
    //Divide por 10 para eliminar a casa da unidade
    //Depois pega o resto da divisão por 10 para isolar a dezena
    dezena := (numero / 10) % 10
    
    fmt.Printf("O algarismo da casa das dezenas é: %d\n", dezena)
}

Exercício 14 - Preço Final de um Carro com Opcionais
package main
import "fmt"
func main(){
    var precoInicial float64
    var opcao string
    
    fmt.Printf("Digite o preço Inicial do Carro: R$ ")
    fmt.Scan(&precoInicial)
    
    precoFinal := precoInicial
    
    //Opçao com Ar Condicionado.
    fmt.Printf("Deseja Carro com AR CONDICIONADO? (s/n)")
    fmt.Scan(&opcao)
    if opcao == "s" {
        precoFinal += 1750.00
    }
    
    //Opcão com Pintura Metálica
    fmt.Printf("Deseja com Pintura Metálica? (s/n)")
    fmt.Scan(&opcao)
    if opcao == "s" {
        precoFinal += 800.00
    }
    //Opcão com Vidro elétrico
    fmt.Printf("Deseja Vidro elétrico? (s/n)")
    fmt.Scan(&opcao)
    if opcao == "s" {
        precoFinal += 1200.00
    }
    //Opcão com Direção Hidráulica
    fmt.Printf("Deseja Direção Hidráulica? (s/n)")
    fmt.Scan(&opcao)
    if opcao == "s" {
        precoFinal += 2000.00
    }

    fmt.Printf("Preço final do carro: R$ %.2f\n", precoFinal)
}






































