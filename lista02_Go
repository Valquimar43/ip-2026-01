Exercício 9 - Um comerciante calcula o valor da venda. Conforme a tabela do exercício
package main
import "fmt"
func main(){

    var valorCompra float64 //Declara a variável para o valor da compra.
    var valorVenda float64 //Declara a variável para a venda.
    
    fmt.Printf("Digite o valor da compra R$ ")
    fmt.Scan(&valorCompra)
    
    //Verifica se o vlaor é inválido primeiro.
    if valorCompra <= 0 {
        fmt.Printf("Valor da compra INVÁLIDO!")
    
    }else if valorCompra < 10{ //valor < 10,00 - lucro de 70% na venda.
        valorVenda = valorCompra * 1.70
        fmt.Printf("Valor da venda é: R$ %.2f\n", valorVenda)
    
    }else if valorCompra < 30 { //valor entre 10,00 a 30,00 - lucro de 50%
        valorVenda = valorCompra * 1.50
        fmt.Printf("Valor da venda é: R$ %.2f\n", valorVenda)
    
    }else if valorVenda < 50 { //valor entre 30,00 a 50,00 - lucro de 40%
        valorVenda = valorCompra * 1.40
        fmt.Printf("Valor da venda é: R$ %.2f\n", valorVenda)
        
    }else{
        valorVenda = valorCompra *1.30
        fmt.Printf("Valor da venda é: R$ %.2f\n", valorVenda)
    }
}

