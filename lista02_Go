Exercício 11 - Calcular valor de "x", dado que: f(x)=8 / (2 - x)
package main
import "fmt"

func main(){
    var x float64
    
    fmt.Printf("Digite o valor para x: ")
    fmt.Scan(&x)
    
    if x == 2 {
        fmt.Printf("ERRO - Divisão por zero! x não pode ser 2.")
    }else{
        resultado := 8 / (2 - x)
        fmt.Printf("f(%.2f) = %.2f\n", x, resultado)
    }
}

