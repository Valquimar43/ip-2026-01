//Exercício 01 - CALCULO DE POTÊNCIA

package main
import "fmt"

func main() {
    var base, exp int
    resultado := 1
    
    fmt.Print("Digite a base: ")
    fmt.Scan(&base)
    
    fmt.Print("Expoente: ")
    fmt.Scan(&exp)
    
    for i := 0; i < exp; i++{
        resultado *= base
    }
    fmt.Printf("Resultado: %d\n", resultado)
}

//Exercício 02 - Soma e média dos pares (50 a 70)

package main

import "fmt"

func main(){
    soma := 0
    pares := [] int {}
    
    for i := 50; i <= 70; i++{
        if i%2 == 0{
            soma += i
            pares = append(pares, i)
        }
    }
    media := float64(soma) / float64(len(pares))
    
    fmt.Println("Valores pares somados entre 50 a 70:  ", pares)
    fmt.Println("Soma: ", soma)
    fmt.Println("Média: ", media)
}

