//Exercício 22 - imprimir a seguinte soma: S= (37*38)/1 + (36*37)/2 + (35*36)/3 + ... +(1*2)/37

package main

import "fmt"

func main (){
    S := 0.0
    
    for k := 1; k <= 37; k++ {
        fator1 := float64(38 - k)       //Drecresse: 37, 36, 35...
        // - Fator1 = 38 - k -> 37, 36, 35, ..., 1
        
        fator2 := float64(39 - k)       //Decresce: 38, 37, 36 ...
        // - Fator2 = 39 - k -> 38, 37, 36, ..., 2
        
        // Denominador = k -> 1, 2, 3, ..., 37
        S += (fator1 * fator2) / float64(k)
    }
    fmt.Printf("S = %.6f\n", S)
}


Exercício 23 - Calcule a série: 1000/1 - 997/2 + 994/3 - 991/4 + ... 

package main

import "fmt"

func main (){
    var n int
    fmt.Print("Digite N (quantidade de termos): ")
    fmt.Scan(&n)
    
    if n > 334 {
        fmt.Println("N muito grande! Usando 334 termos.")
        n = 334
    }
    
    S := 0.0
    sinal := 1.0        // Inicia com positivo
    numerador := 1000.0
    
    for k := 1; k <= n; k++ {
        S += sinal * (numerador / float64(k))
        sinal *= -1         //Inverte o Sinal a cada interação.
        numerador -= 3      //Reduz o numerador de 3 em 3
    }
    fmt.Printf("S = %6f\n", S)
}


