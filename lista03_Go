//Exercício 12 - Somatórios S = X - X/1! + X/2!

package main

import "fmt"

func main(){
    var x float64
    
    fmt.Println("Digite o valor de X: ")
    fmt.Scan(&x)
    
    soma := x           //Primeiro termo é "x"
    fatorial := 1.0
    sinal := -1.0       //O segundo termo é negativo, alterna a cada passo.
    
    for i := 1; i <= 19; i++ {
        fatorial *= float64(i)      //Acumula o fatorial - Evita recalcular do zero
        soma += sinal * (x / fatorial)
        sinal *= -1                 //Inverte o sinal para o próximo termo!
    }
    fmt.Printf("S = %.6f\n", soma)
}
