//Exercício 16 - Série FETUCCINE.
    //Os dois primeiros termos são fornecidos pelo usuário.
    //A partir do 3º termo:
        //  -Se o INDICE do termos for ímpar: Ai= Ai-1 + Ai+2 (Soma)
        //  -Se o ÍNDICE do termo for par: Ai= Ai-1 - Ai-2 (Subtração)
    //EXEMPLO DE SAÍDA COM A1= 3, A2=7, N=6
    // A3 (índice 3, ímpar): 7 + 3 = 10
    // A4 (índice 4, par): 10 - 7 = 3
    // A5 (índice 5, ímpar): 3 + 10 = 13
    // A6 (índice 6, par): 13 - 3 = 10

package main

import "fmt"

func main (){
    var a1, a2, n int
    
    fmt.Print("Digite o primeiro termo: ")
    fmt.Scan(&a1)
    fmt.Print("Digite o segundo termo: ")
    fmt.Scan(&a2)
    fmt.Print("Digite N (N >= 3): ")
    fmt.Scan(&n)
    
    termos := make([]int, n)
    termos[0] = a1
    termos[1] = a2
    
    for i := 2; i < n; i++ {
        indice := i + 1     //indice real começa em 1 (i + 2 -> índice 3)
        if indice%2 != 0 {
            termos[i] = termos[i - 1] + termos[i - 2] //Ímpar: Soma
        }else{
            termos[i] = termos[i-1] - termos[i-2] //Para: Subtração
        }
    }
    
    fmt.Print("Série de FETUCCINE: ")
    
    for _, v := range termos {
        fmt.Printf("%d ", v)
    }
    fmt.Println()
}

