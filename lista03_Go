        fmt.Scan(&opcao)
    }
    if count10a20 > 0 {
        fmt.Println("Média das alturas (10 - 20): ", somaAltura/float64(count10a20))
    }else{
        fmt.Println("Nenhuma pessoa entre 10 e 20 anos!")
    }
    fmt.Println("Pessoas com mais de 50 anos: ", mais50)
    
    if total > 0 {
        fmt.Println("Percentual abaixo de 40Kg: ", float64(menos40)/float64(total)*100, "%")
    }
}

//Exercício 06 - NUMERO TRIANGULAR (Rusltado do produto de três números naturais consecutivos)

package main

import "fmt"

func main(){
    var n int
    
    fmt.Printf("Digite um número: ")
    fmt.Scan(&n)
    
    encontrou := false
    
    for i := 1; i * (i+1)*(i+2) <= n; i++ {
        if i*(i+1)*(i+2) == n {
            encontrou = true
            break
        }
    }
    if encontrou {
        fmt.Println("É um número triangular!")
    }else {
        fmt.Println("Não é um número triangular!")
    }
}

//Exercício 07 - Estatísticas até digitar 30.000!

package main

