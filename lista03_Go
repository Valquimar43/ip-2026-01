    for{
        fmt.Printf("Digite um número (30.000 para sair): ")
        fmt.Scan(&num)
        
        if num == 30000 {
            break
        }
    
        if quantidade == 0{
        maior = num
        menor = num
    }
    
    soma += num
    quantidade++
    
    if num > maior{
        maior = num
    }
    if num < menor {
        menor = num
    }
    if num%2 == 0 {
        somaPares += num
        countPares++
    }else {
        countImpares++
    }
}
if quantidade > 0 {
    fmt.Println("Soma: ", soma)
