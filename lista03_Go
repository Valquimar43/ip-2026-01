//Exercício 25 - Calcule S= 1/225 - 2/196 + 4/169 - 8/144 + ... + 16384/1

package main

import "fmt"

func main(){
    S := 0.0
    sinal := 1.0
    numerador := 1.0        //inicia em 2^0 = 1
    denominador := 15.0     //inicia em 15 (15² = 225)
    
    for denominador >= 1 {
        S += sinal * (numerador / (denominador * denominador))
        sinal *= -1         //Alterana o sinal.
        numerador *= 2      //Dobra: 1, 2, 4, 8, 16...
        denominador -= 1    //Diminiu: 15, 14, 13...
        
    }
    
    fmt.Printf("S = %.8f\n", S)
}

//Exercício 26 - Calcule e escreva os 20 primeiros termos de:
//100/0! + 99/1! + 98/2! + 97/3! ...*/
//
//para o k-ésimo termo (k inicia em 0)
//      Numerdaor: 100 - k -> 100, 99, 98, 97...
//      Denominador: k!     -> 0!, 1!, 2!, 3!...
//
//O fatorial é calculado de fomra incremental, exemplo:
//  k=0 -> 0! = 1
//  k=1 -> 1! = 1*1 = 1
//  k=2 -> 2! = 1*2 = 2
//  k=3 -> 3! = 2*3 = 6 ... assim por diante!

package main

import "fmt"

func main (){
    S := 0.0
    fatorial := 1.0         //inicia com 0! = 1
    
    for k := 0; k < 20; k++ {
        if k < 0{
            fatorial *= float64(k)      //Atualiza: Fatorial = fatorial anterior * k
        }
        numerador := float64(100 - k)
        S += numerador / fatorial
    }
    fmt.Printf("Soma dos 20 primeiros termos = %.4f\n", S)
    
}












